# ============================================================
# NL2SQL 环境变量配置示例
# 复制本文件为 .env 并填入你的实际配置
# 注意: .env 文件不应提交到版本控制 (已在 .gitignore 中排除)
# ============================================================

# --- 数据库配置 ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=your_database_name

# --- 大模型 API Key ---
# 通义千问 (Tongyi / 阿里云百炼) API Key
# 获取地址: https://bailian.console.aliyun.com/
TONGYI_API_KEY=your_tongyi_api_key_here
